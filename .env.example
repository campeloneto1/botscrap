# Backend
SECRET_KEY=sua-chave-secreta-muito-longa-aqui-mude-em-producao
DEBUG=false

# Timezone - Fuso horário da aplicação
TIMEZONE=America/Fortaleza

# Admin User (criado automaticamente no startup)
ADMIN_EMAIL=admin@botscrap.com
ADMIN_PASSWORD=admin123

# Database (usado pelo docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/botscrap

# Telegram Bot - OBRIGATÓRIO para o bot funcionar
# 1. Abra o Telegram e busque @BotFather
# 2. Envie /newbot e siga as instruções
# 3. Cole o token abaixo
# IMPORTANTE: O bot será iniciado automaticamente com docker-compose up
TELEGRAM_BOT_TOKEN=seu_token_do_botfather

# Credenciais do bot para acessar a API (opcional)
# Por padrão usa admin/admin123, mas você pode criar um usuário específico
BOT_API_USERNAME=admin
BOT_API_PASSWORD=admin123

# Instagram - Conta para scraping (opcional, melhora rate limits)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Twitter/X - Conta para scraping (OBRIGATÓRIO para acessar conteúdo)
# Twitter agora exige login para ver a maioria do conteúdo
TWITTER_USERNAME=
TWITTER_PASSWORD=

# Facebook - Conta para scraping (OBRIGATÓRIO para acessar conteúdo)
# Use email ao invés de username
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# Scraping
SCRAPE_INTERVAL_HOURS=6
SCRAPE_DELAY_SECONDS=3

# AI Summary - Groq API (gratuito: https://console.groq.com)
GROQ_API_KEY=
ENABLE_AI_SUMMARY=true

# Proxies (opcional)
USE_PROXIES=false
PROXY_LIST=
